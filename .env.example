# Copy this file to .env or to your systemd EnvironmentFile and fill in real values.
# The repository defaults are intended for local development only.

OJ_ENV=development
PORT=8090
OJ_DB_FILE=state/oj.sqlite3

# Required in production.
OJ_ADMIN_USERNAME=admin
OJ_ADMIN_PASSWORD=change-me-with-a-long-random-password
OJ_REGISTRATION_INVITE_CODE=change-me-invite-code
OJ_JWT_SECRET=change-me-at-least-32-random-bytes

# OpenAI-compatible model endpoint used by contestant agents.
# Contestants can also configure their own endpoint from the profile page.
OJ_DEFAULT_MODEL=gpt-4o-mini

# OpenAI-compatible grading endpoint used by the platform.
OJ_GRADER_BASE_URL=https://api.example.com/v1
OJ_GRADER_MODEL=grader-model-name
OJ_GRADER_API_KEY=replace-with-grader-key
OJ_GRADER_LABEL=Platform grading API

# Hermes runner.
OJ_HERMES_DOCKER=1
OJ_HERMES_DOCKER_IMAGE=hermes-agent:latest
OJ_HERMES_DOCKER_NETWORK=bridge
OJ_HERMES_TOOLSETS=terminal
OJ_AGENT_TIMEOUT_SECONDS=1800
OJ_JUDGE_TIMEOUT_SECONDS=900
OJ_FAULT_SCRIPT_TIMEOUT_SECONDS=300

# Optional local demo fault target.
VOTING_APP_DIR=/opt/example-voting-app

# Optional remote fault target for private deployments. Do not commit real values.
FAULT_TARGET_HOST=
FAULT_TARGET_USER=root
FAULT_TARGET_PORT=22
FAULT_TARGET_IDENTITY_FILE=/path/to/private/key

# Optional multi-cloud Robot Shop read-only MCP values for private deployments.
MC_ALIYUN_HOST=203.0.113.10
MC_ALIYUN_USER=ojobserver
MC_TENCENT_HOST=198.51.100.10
MC_TENCENT_USER=ojobserver
MC_ROBOT_APP_DIR=/opt/mc-robot-shop
MC_SSH_IDENTITY_FILE=/path/to/private/key
