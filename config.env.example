#!/bin/bash
# ============================================================
# SRE-OJ 靶场部署配置
# 复制此文件为 config.env 并填写实际值：
#   cp config.env.example config.env
# SSH 用户建议使用 root；如使用 ubuntu 等非 root 用户，必须已配置免密 sudo。
# 服务器1/2/3 可以是三台不同服务器，也可以部分或全部填写同一个 IP。
# ============================================================

# === 服务器1（入口/前端角色） ===
SERVER1_IP=
SERVER1_USER=root
SERVER1_PASS=
SERVER1_KEY=                # SSH 密钥文件路径（与密码二选一）

# === 服务器2（数据服务角色） ===
SERVER2_IP=
SERVER2_USER=root
SERVER2_PASS=
SERVER2_KEY=

# === 服务器3（履约服务角色） ===
SERVER3_IP=
SERVER3_USER=root
SERVER3_PASS=
SERVER3_KEY=

# === OJ 服务器（可选，第 4 个角色；可与上面任一服务器相同） ===
OJ_ENABLED=false
OJ_IP=
OJ_USER=root
OJ_PASS=
OJ_KEY=


# === OJ 生产配置（OJ_ENABLED=true 时使用） ===
OJ_PORT=8090
OJ_ADMIN_USERNAME=admin
OJ_ADMIN_PASSWORD=dev-admin-password
OJ_REGISTRATION_INVITE_CODE=dev-invite-code
OJ_JWT_SECRET=change-me-at-least-32-random-bytes-for-oj
OJ_GRADER_BASE_URL=https://api.example.com/v1
OJ_GRADER_MODEL=grader-model-name
OJ_GRADER_API_KEY=replace-with-grader-key
OJ_HERMES_DOCKER_IMAGE=hermes-agent:latest

# === APM 可观测（可选） ===
APM_ENABLED=false
APM_ENDPOINT=
APM_TOKEN=

# === 部署选项 ===
SKIP_K3S_INSTALL=false        # 如果服务器已有 k3s，设为 true
SKIP_BASE_IMAGE_IMPORT=false  # 如果 k3s/Chaos Mesh 基础镜像已导入，设为 true
SKIP_CHAOS_MESH=false         # 如果已有 Chaos Mesh，设为 true
SKIP_IMAGE_IMPORT=false       # 如果镜像已导入，设为 true
SKIP_ACCESS_GENERATION=false  # 如果不需要生成本地 kubeconfig/token，设为 true
IMAGES_DIR=                   # 离线镜像目录；为空时使用 ./images

# === 制品下载（推荐用于真实一键部署） ===
# K3S_BINARY_URL 填 k3s 二进制直链后，服务器会先下载二进制，再用 INSTALL_K3S_SKIP_DOWNLOAD 安装。
# K3S_BINARY_PATH 仅作为临时兜底；真实一键部署应让服务器自己从 Release/对象存储拉取。
ARTIFACT_BASE_URL=https://github.com/Maijintao/MultiCloudSRE-Ops/releases/download/deploy-artifacts-20260701
K3S_INSTALL_URL=${ARTIFACT_BASE_URL}/install.sh
K3S_BINARY_URL=${ARTIFACT_BASE_URL}/k3s
K3S_BINARY_PATH=

# k3s/Chaos Mesh 基础镜像包，必须在安装 Chaos Mesh 前导入。
# 包含 rancher pause/coredns/metrics/local-path 以及 ghcr.io/chaos-mesh/*。
# 正常发布时放在同一个 Release/对象存储下；服务器必须能直接访问该地址。
# BASE_IMAGE_TAR_PATH 仅作为临时兜底，不作为真实一键部署路径。
BASE_IMAGE_BUNDLE_NAME=k3s-chaos-base-images.tar
BASE_IMAGE_ARTIFACT_URL=${ARTIFACT_BASE_URL}/${BASE_IMAGE_BUNDLE_NAME}
BASE_IMAGE_TAR_PATH=

# 业务镜像导入模式：
#   local  本机从 IMAGE_ARTIFACT_BASE_URL 下载并解压镜像包，再自动上传到服务器导入（默认，国内云更稳）
#   remote 服务器直接从 IMAGE_ARTIFACT_BASE_URL 下载镜像包并导入
IMAGE_IMPORT_MODE=local

# IMAGE_ARTIFACT_BASE_URL 填 Release/对象存储目录后，本机会自动下载：
#   common-image-tars.tar.gz、aliyun-image-tars.tar.gz、tencent-image-tars.tar.gz、aws-image-tars.tar.gz
# 可用 scripts/package-image-artifacts.sh 从 IMAGES_DIR 重新生成这些包。
IMAGE_ARTIFACT_BASE_URL=${ARTIFACT_BASE_URL}

UPDATE_LOCAL_KUBECONFIG=true  # 是否自动合并三角色 context 到本机 ~/.kube/config
DEPLOY_QUESTIONS=false        # 题目 inject/recover 脚本部署，环境部署默认不启用

# 如果服务器1和服务器3 是同一台，默认会自动把 paymentservice NodePort 从 30051 改为 30075。
# 需要自定义时可以显式设置：
PAYMENT_SERVICE_NODEPORT=
