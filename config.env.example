#!/bin/bash
# ============================================================
# SRE-OJ 靶场部署配置
# 复制此文件为 config.env 并填写实际值：
#   cp config.env.example config.env
# SSH 用户建议使用 root；如使用 ubuntu 等非 root 用户，必须已配置免密 sudo。
# ============================================================

# === 阿里云靶机（流量入口） ===
ALIYUN_IP=
ALIYUN_USER=root
ALIYUN_PASS=
ALIYUN_KEY=                  # SSH 密钥文件路径（与密码二选一）

# === 腾讯云靶机（数据层） ===
TENCENT_IP=
TENCENT_USER=ubuntu
TENCENT_PASS=
TENCENT_KEY=

# === AWS 靶机（履约链） ===
AWS_IP=
AWS_USER=ubuntu
AWS_PASS=
AWS_KEY=

# === 在线 OJ 系统（可选，第 4 台服务器） ===
OJ_ENABLED=false
OJ_IP=
OJ_USER=
OJ_PASS=
OJ_KEY=

# === APM 可观测（可选） ===
APM_ENABLED=false
APM_ENDPOINT=
APM_TOKEN=

# === 部署选项 ===
SKIP_K3S_INSTALL=false       # 如果服务器已有 k3s，设为 true
SKIP_CHAOS_MESH=false        # 如果已有 Chaos Mesh，设为 true
SKIP_IMAGE_IMPORT=false      # 如果镜像已导入，设为 true
SKIP_ACCESS_GENERATION=false   # 如果不需要生成本地 kubeconfig/token，设为 true
IMAGES_DIR=                  # 离线镜像目录；为空时使用 ./images
UPDATE_LOCAL_KUBECONFIG=true   # 是否自动合并三云 context 到本机 ~/.kube/config
DEPLOY_QUESTIONS=false         # 题目 inject/recover 脚本部署，环境部署默认不启用
