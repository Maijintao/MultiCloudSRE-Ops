#!/usr/bin/env python3
"""Root-owned allowlist gateway for real read-only Robot Shop observations."""

import os
import re
import subprocess
import sys
from pathlib import Path
from urllib.parse import urlparse


APP_DIR = Path(os.environ.get("MC_ROBOT_APP_DIR", "/opt/mc-robot-shop")).resolve()
CLOUD = os.environ.get("MC_ROBOT_CLOUD", "aliyun").strip().lower()
ALIYUN_HOST = os.environ.get("MC_ALIYUN_HOST", "203.0.113.10")
TENCENT_HOST = os.environ.get("MC_TENCENT_HOST", "198.51.100.10")
MAX_OUTPUT_CHARS = int(os.environ.get("OJ_MULTI_CLOUD_MCP_MAX_OUTPUT_CHARS", "60000"))
COMPOSE = ["docker", "compose", "-f", "docker-compose.yml"]
SERVICES = {
    "mongodb",
    "redis",
    "rabbitmq",
    "catalogue",
    "user",
    "cart",
    "mysql",
    "shipping",
    "ratings",
    "payment",
    "dispatch",
    "web",
    "edge",
}
GATEWAY_ALIAS = "gateway"
GATEWAY_CONTAINER = "mc-robot-gateway"
SAFE_NAME = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$")
SAFE_KEY = re.compile(r"^[A-Za-z0-9][A-Za-z0-9:_.-]{0,255}$")
SAFE_HOST = re.compile(r"^[A-Za-z0-9][A-Za-z0-9.-]{0,252}$")
ALLOWED_HTTP_HOSTS = {
    "127.0.0.1",
    "localhost",
    ALIYUN_HOST,
    TENCENT_HOST,
    "global.robot-shop.local",
    "robot-shop.local",
}
ALLOWED_HTTP_PORTS = {80, 443, 18080, 18081, 18443}
ALLOWED_SYSCTLS = {
    "net.ipv4.ip_local_port_range",
    "net.ipv4.tcp_max_syn_backlog",
    "net.core.somaxconn",
    "net.netfilter.nf_conntrack_count",
    "net.netfilter.nf_conntrack_max",
    "vm.swappiness",
}
ALLOWED_PROC_FILES = {
    "/proc/pressure/cpu",
    "/proc/pressure/io",
    "/proc/pressure/memory",
    "/proc/net/softnet_stat",
    "/proc/net/netstat",
    "/proc/net/snmp",
    "/proc/vmstat",
    "/proc/meminfo",
    "/proc/sys/fs/file-nr",
}
ALLOWED_CONTAINER_FILES = {
    ("shipping", "/tmp/mc-gc.log"),
    ("shipping", "/proc/1/status"),
    ("cart", "/sys/fs/cgroup/pids.current"),
    ("cart", "/sys/fs/cgroup/pids.max"),
    ("cart", "/sys/fs/cgroup/pids/pids.current"),
    ("cart", "/sys/fs/cgroup/pids/pids.max"),
}
MYSQL_FORBIDDEN = re.compile(
    r"\b(?:INSERT|UPDATE|DELETE|REPLACE|ALTER|DROP|CREATE|TRUNCATE|GRANT|REVOKE|KILL|SET|CALL|LOAD|LOCK|UNLOCK|INTO\s+OUTFILE|INTO\s+DUMPFILE)\b",
    re.IGNORECASE,
)
MYSQL_ALLOWED_START = re.compile(r"^\s*(?:SHOW|SELECT|EXPLAIN|DESC(?:RIBE)?)\b", re.IGNORECASE)
MONGO_FORBIDDEN = re.compile(
    r"\.(?:insert|insertOne|insertMany|update|updateOne|updateMany|delete|deleteOne|deleteMany|remove|drop|createIndex|dropIndex|setProfilingLevel|runCommand)\s*\(",
    re.IGNORECASE,
)
MONGO_ALLOWED = re.compile(
    r"^(?:db\.)?(?:getSiblingDB\([^)]+\)\.)?(?:products\.(?:find|findOne|getIndexes|stats)\b|system\.profile\.(?:find|stats)\b|getProfilingStatus\b)",
    re.IGNORECASE,
)


